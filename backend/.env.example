# ──────────────────────────────────────────────────────────
# BNB Sentiment Sentinel — Environment Configuration
# ──────────────────────────────────────────────────────────
# Copy this to .env and fill in your values.
# All values have sane defaults for demo/mock mode.

# Set to False for live on-chain execution
MOCK_MODE=True

# CoinMarketCap API Key (optional — Trial Pro API is keyless)
# Get one at: https://coinmarketcap.com/api/
CMC_API_KEY=MOCK_CMC_API_KEY_SENTINEL_2026

# Trust Wallet Agent Kit credentials
# Get them at: https://portal.trustwallet.com/dashboard/apps
TWAK_ACCESS_ID=MOCK_TWAK_ACCESS_ID
TWAK_HMAC_SECRET=MOCK_TWAK_HMAC_SECRET

# Agent Private Key (BSC Testnet — NEVER use a mainnet key with funds)
AGENT_PRIVATE_KEY=0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# BSC RPC URL
RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/

# IPFS JWT for deliverable uploads (optional)
IPFS_JWT=MOCK_IPFS_JWT

# Contract Addresses
ERC8004_REGISTRY_ADDR=0x8004000000000000000000000000000000000000
ERC8183_COMMERCE_ADDR=0x8183000000000000000000000000000000000000
